{
	"hosting": [
		{
			"target": "landing",
			"public": "build",
			"ignore": [
				"firebase.json",
				"**/.*",
				"**/node_modules/**",
				"index.html",
				"chat.html",
				"robots-agent.txt",
				"sitemap.xml"
			],
			"cleanUrls": true,
			"headers": [
				{
					"source": "**",
					"headers": [
						{ "key": "X-Content-Type-Options", "value": "nosniff" },
						{ "key": "X-Frame-Options", "value": "DENY" },
						{ "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
						{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" },
						{ "key": "Permissions-Policy", "value": "camera=(), microphone=(self), geolocation=()" }
					]
				}
			],
			"redirects": [
				{
					"source": "/agent/chat{,/**}",
					"destination": "https://agent.superextra.ai/chat",
					"type": 301
				},
				{
					"source": "/agent{,/**}",
					"destination": "https://agent.superextra.ai",
					"type": 301
				},
				{
					"source": "/chat{,/**}",
					"destination": "https://agent.superextra.ai/chat",
					"type": 301
				}
			],
			"rewrites": [
				{
					"source": "/robots.txt",
					"destination": "/robots-landing.txt"
				},
				{
					"source": "/api/intake",
					"function": "intake"
				},
				{
					"source": "/api/stt-token",
					"function": "sttToken"
				},
				{
					"source": "/api/tts",
					"function": "tts"
				},
				{
					"source": "/",
					"destination": "/landing.html"
				}
			]
		},
		{
			"target": "agent",
			"public": "build",
			"ignore": [
				"firebase.json",
				"**/.*",
				"**/node_modules/**",
				"landing.html",
				"robots-landing.txt"
			],
			"cleanUrls": true,
			"headers": [
				{
					"source": "/chat{,/**}",
					"headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" }]
				},
				{
					"source": "/chat.html",
					"headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" }]
				},
				{
					"source": "**",
					"headers": [
						{ "key": "X-Content-Type-Options", "value": "nosniff" },
						{ "key": "X-Frame-Options", "value": "DENY" },
						{ "key": "Referrer-Policy", "value": "no-referrer" },
						{ "key": "Permissions-Policy", "value": "camera=(), microphone=(self), geolocation=()" }
					]
				}
			],
			"redirects": [
				{
					"source": "/agent/chat",
					"destination": "/chat",
					"type": 301
				},
				{
					"source": "/agent",
					"destination": "/",
					"type": 301
				}
			],
			"rewrites": [
				{
					"source": "/robots.txt",
					"destination": "/robots-agent.txt"
				},
				{
					"source": "/api/intake",
					"function": "intake"
				},
				{
					"source": "/api/agent/stream",
					"function": "agentStream"
				},
				{
					"source": "/api/agent/cancel",
					"function": "agentCancel"
				},
				{
					"source": "/api/agent/delete",
					"function": "agentDelete"
				},
				{
					"source": "/api/auth/send-magic-link",
					"function": "sendMagicLink"
				},
				{
					"source": "/api/stt-token",
					"function": "sttToken"
				},
				{
					"source": "/api/tts",
					"function": "tts"
				}
			]
		}
	],
	"functions": [
		{
			"source": "functions",
			"codebase": "default",
			"runtime": "nodejs22"
		}
	],
	"firestore": {
		"rules": "firestore.rules",
		"indexes": "firestore.indexes.json"
	},
	"emulators": {
		"firestore": {
			"port": 8088
		},
		"ui": {
			"enabled": false
		},
		"singleProjectMode": true
	}
}
