rules_version = '2';

// Capability-URL access model (server-stored sessions plan §6):
// - `get` on session/turn/event paths: open to any signed-in visitor.
// - `list` on /sessions: constrained to participants (query must include
//   `where('participants', 'array-contains', uid)`).
// - All writes server-only via Admin SDK (Cloud Functions + Reasoning Engine plugin).
service cloud.firestore {
  match /databases/{database}/documents {
    match /sessions/{sid} {
      allow get: if request.auth != null;

      allow list: if request.auth != null
                  && request.auth.uid in resource.data.participants;

      allow write: if false;

      match /turns/{turnId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      match /events/{eventId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // Per-user account doc (identity + plan + daily research-runs counter).
    // Owner-read only; all writes server-only — Cloud Functions handle
    // identity lazy-provision on agentStream; the agent's quota gate
    // (agent/superextra_agent/quota_gate.py) atomically reserves the daily
    // research-runs counter inside research_pipeline.
    match /users/{uid} {
      allow get: if request.auth != null && request.auth.uid == uid;
      allow list: if false;
      allow write: if false;
    }

  }
}
